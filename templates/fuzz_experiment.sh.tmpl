#!/usr/bin/env bash
# Fuzzing experiment runner script
# Generated by fuzz-setup skill — customize as needed
#
# Usage:
#   ./fuzz_experiment.sh --duration 10m --output-dir results/run-001/trial-01 --trial-id 1

set -euo pipefail

# --- Parse arguments ---
DURATION="10m"
OUTPUT_DIR="results/default"
TRIAL_ID="1"

while [[ $# -gt 0 ]]; do
    case $1 in
        --duration)   DURATION="$2"; shift 2 ;;
        --output-dir) OUTPUT_DIR="$2"; shift 2 ;;
        --trial-id)   TRIAL_ID="$2"; shift 2 ;;
        *) echo "Unknown argument: $1"; exit 1 ;;
    esac
done

# --- Configuration (edit these) ---
FUZZER_DIR="{{FUZZER_DIR}}"       # e.g., fuzzers/aflpp
FUZZER_BIN="{{FUZZER_BIN}}"       # e.g., fuzzers/aflpp/afl-fuzz
TARGET="{{TARGET}}"               # path to instrumented binary
SEEDS_DIR="{{SEEDS_DIR}}"         # path to seed corpus
DICT=""                           # optional: path to dictionary file

# Resolve to absolute paths
PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
FUZZER_BIN="${PROJECT_ROOT}/${FUZZER_BIN}"
export AFL_PATH="${PROJECT_ROOT}/${FUZZER_DIR}"
export PATH="${PROJECT_ROOT}/${FUZZER_DIR}:$PATH"

# Convert duration to seconds
duration_to_sec() {
    local d="$1"
    case "$d" in
        *h) echo $(( ${d%h} * 3600 )) ;;
        *m) echo $(( ${d%m} * 60 )) ;;
        *s) echo "${d%s}" ;;
        *)  echo "$d" ;;
    esac
}
DURATION_SEC=$(duration_to_sec "$DURATION")

# --- Setup output directory ---
mkdir -p "$OUTPUT_DIR"

echo "[experiment] Trial $TRIAL_ID starting: fuzzer={{FUZZER}}, duration=$DURATION"
echo "[experiment] Output: $OUTPUT_DIR"

# --- Pre-check: verify target exists ---
if [ ! -x "$TARGET" ]; then
    echo "[experiment] ERROR: Target binary not found or not executable: $TARGET"
    exit 1
fi

# --- Run fuzzer ---
START_TIME=$(date +%s)

# {{FUZZER_COMMAND}} — replace with actual fuzzer invocation
# Example for AFL++:
#   "$FUZZER_BIN" -i "$SEEDS_DIR" -o "$OUTPUT_DIR" -V "$DURATION_SEC" -m none -- "$TARGET" @@

{{FUZZER_COMMAND}}

EXIT_CODE=$?
END_TIME=$(date +%s)
ELAPSED=$(( END_TIME - START_TIME ))

echo "[experiment] Fuzzer finished: exit_code=$EXIT_CODE, elapsed=${ELAPSED}s"

# --- Collect coverage ---
python3 tools/coverage.py \
    --method {{COVERAGE_METHOD}} \
    --output-dir "$OUTPUT_DIR" \
    --save "$OUTPUT_DIR/coverage.json" \
    2>/dev/null || true

# --- Collect crashes ---
CRASH_DIR="$OUTPUT_DIR/{{CRASH_SUBDIR}}"
if [ -d "$CRASH_DIR" ]; then
    python3 tools/crash.py \
        --crash-dir "$CRASH_DIR" \
        --binary "$TARGET" \
        --output "$OUTPUT_DIR/crash_analysis.json" \
        2>/dev/null || true
fi

# --- Write per-trial stats ---
python3 -c "
import json, os
stats = {
    'trial_id': $TRIAL_ID,
    'duration_sec': $ELAPSED,
    'exit_code': $EXIT_CODE,
}
cov_file = '$OUTPUT_DIR/coverage.json'
if os.path.exists(cov_file):
    with open(cov_file) as f:
        cov = json.load(f)
    stats['branch_cov'] = cov.get('edges', 0) or cov.get('branches', 0) or cov.get('lines', 0)
crash_file = '$OUTPUT_DIR/crash_analysis.json'
if os.path.exists(crash_file):
    with open(crash_file) as f:
        crash = json.load(f)
    stats['unique_crashes'] = crash.get('unique_crashes', 0)
with open('$OUTPUT_DIR/stats.json', 'w') as f:
    json.dump(stats, f, indent=2)
"

# --- Output METRIC lines (parsed by fuzz-loop) ---
if [ -f "$OUTPUT_DIR/stats.json" ]; then
    python3 -c "
import json
with open('$OUTPUT_DIR/stats.json') as f:
    s = json.load(f)
for k, v in s.items():
    if k not in ('trial_id', 'duration_sec', 'exit_code') and isinstance(v, (int, float)):
        print(f'METRIC {k}={v}')
"
fi

echo "[experiment] Trial $TRIAL_ID complete"
exit $EXIT_CODE
